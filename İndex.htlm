<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>İE'sra BAL | The Vault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap');
    
    .serif { font-family: 'Cormorant Garamond', serif; }
    .sans { font-family: 'Inter', sans-serif; }
    .gold-gradient { background: linear-gradient(90deg, #d4af37, #f5d76e, #d4af37); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .hero-bg {
      background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.9)), url('https://picsum.photos/id/1015/2000/1200');
      background-size: cover;
      background-position: center;
    }

    .fade-in {
      animation: fadeIn 1.5s ease forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .glow {
      animation: glow 3s ease-in-out infinite alternate;
    }

    @keyframes glow {
      from { text-shadow: 0 0 20px rgba(245, 158, 11, 0.6); }
      to { text-shadow: 0 0 40px rgba(245, 158, 11, 0.9); }
    }

    .vault-enter {
      transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }
  </style>
</head>
<body class="bg-black text-white sans overflow-x-hidden">

<!-- VAULT ENTRY -->
<div id="vault" class="fixed inset-0 bg-black z-50 flex items-center justify-center vault-enter">
  <div class="text-center max-w-md mx-auto px-6 fade-in">
    <i class="fas fa-gem text-amber-400 text-8xl mb-8 glow"></i>
    <h1 class="serif text-6xl gold-gradient mb-4 tracking-tight">THE VAULT</h1>
    <p class="text-amber-300 text-sm tracking-[4px] mb-10">PRIVATE ARCHIVE • EXCLUSIVE</p>
    <p class="text-white/70 mb-12 leading-relaxed">
      Sadece seçkinler için.<br>
      Sadece yetişkinler için.
    </p>
    <button onclick="enterVault()" 
      class="w-full py-6 bg-gradient-to-r from-amber-500 to-yellow-600 text-black font-bold text-xl tracking-widest hover:scale-105 transition-all duration-300">
      ENTER THE VAULT
    </button>
  </div>
</div>

<!-- MAIN CONTENT -->
<div id="main" class="hidden">

  <!-- HERO -->
  <section class="hero-bg h-screen flex items-center justify-center text-center relative">
    <div class="relative z-10 px-6 max-w-3xl fade-in">
      <p class="text-amber-400 text-sm tracking-[6px] mb-4">İE'SRA BAL</p>
      <h1 class="serif text-7xl md:text-8xl font-light leading-none mb-6 gold-gradient">Gizli Arşiv</h1>
      <p class="text-xl text-white/80 max-w-xl mx-auto mb-12">
        Kamuoyuna açık olanlar sadece buzdağının görünen kısmıydı.
      </p>
      <a href="#gallery" 
        class="inline-block px-12 py-6 border-2 border-amber-400 hover:bg-amber-400 hover:text-black transition text-lg font-medium">
        Koleksiyona Gir
      </a>
    </div>
  </section>

  <!-- VIP CTA -->
  <section class="py-24 text-center bg-gradient-to-b from-zinc-950 to-black">
    <div class="max-w-md mx-auto px-6 fade-in">
      <h2 class="serif text-5xl mb-6">Tam Erişim</h2>
      <p class="text-white/70 mb-10">Tüm özel fotoğraflar, videolar ve kişisel arşiv sadece VIP üyeler için.</p>
      <a href="https://t.me/yourvipchannel" 
        class="block w-full py-6 bg-amber-500 text-black font-bold text-xl rounded-2xl hover:bg-amber-400 transition transform hover:scale-105">
        VIP Kanalına Katıl →
      </a>
    </div>
  </section>

</div>

<script>
function enterVault() {
  const vault = document.getElementById('vault');
  const main = document.getElementById('main');
  
  vault.style.opacity = '0';
  setTimeout(() => {
    vault.classList.add('hidden');
    main.classList.remove('hidden');
  }, 800);
}
</script>

</body>
</html>
